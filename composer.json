{
    "name": "farn/easyicon",
    "type": "wordpress-plugin",
    "autoload": {
        "psr-4": {
            "Farn\\EasyIcon\\": "src/"
        }
    },
    "authors": [
        {
            "name": "farnlabs",
            "email": "info@farnlabs.de"
        }
    ],
    "repositories": [
        {
            "type": "vcs",
            "url": "git@github.com:FARN-Design/farn-core.git"
        },
        {
            "type": "package",
          "package": {
            "name": "phenx/php-font-lib",
            "version": "dev-master",
            "source": {
              "url": "https://github.com/NLion74/php-font-lib",
              "type": "git",
              "reference": "master"
            }
          }
        }
    ],
    "require": {
        "farn/farn-core": "dev-main",
      "phenx/php-font-lib": "dev-master"
    },
    "require-dev": {
        "phpunit/phpunit": "^9",
        "yoast/phpunit-polyfills": "^1.0",
        "doctrine/instantiator": "^1.5.0"
    },
    "scripts": {
        "wp": "vendor/bin/wp"
    }
}
